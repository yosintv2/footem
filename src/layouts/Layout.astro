---
import Header from '../components/Header';
import Footer from '../components/Footer';
import { config } from '../config';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title = `${config.site.name} - ${config.site.tagline}`, description = config.site.description, image } = Astro.props;
---

<!DOCTYPE html>
<html lang={config.site.locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:locale" content={config.site.ogLocale} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={config.site.url} />
  <meta property="og:site_name" content={config.site.name} />
  <meta name="twitter:card" content={config.site.twitterCard} />
  {image && <meta property="og:image" content={image} />}
  <meta name="robots" content={config.site.robots} />
  <link rel="canonical" href={config.site.url} />
  <link rel="icon" type="image/x-icon" href={config.site.favicon} />
  <link rel="preconnect" href={config.fonts.preconnect[0]} />
  <link rel="preconnect" href={config.fonts.preconnect[1]} crossorigin />
  <link href={config.fonts.css} rel="stylesheet" />
  <link rel="alternate" type="application/rss+xml" title={`${config.site.name} &raquo; Feed`} href={config.links.rss} />

</head>
<body>

  <div style="position:fixed;top:0;left:0;width:100%;height:1px;overflow:hidden;visibility:hidden;z-index:9999;">
    <script type="text/javascript" src="//widget.supercounters.com/ssl/online_i.js"></script>
    <script type="text/javascript">sc_online_i(1714446,"ffffff","ffffff");</script>
    <script id="_wau9qe">var _wau = _wau || []; _wau.push(["dynamic", "1qzxz258so", "9qe", "c4302bffffff", "small"]);</script>
    <script async src="//waust.at/d.js"></script>
  </div>
  <Header client:only="react" />
  <main>
    <slot />
  </main>
  <Footer client:only="react" />
</body>
</html>

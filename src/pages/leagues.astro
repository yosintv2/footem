---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar';
import LatestNews from '../components/LatestNews';
import Player from '../components/Player.astro';
import { config } from '../config';
---

<Layout title={`Leagues - ${config.site.name} | ${config.site.tagline}`}>
  <div class="page-wrap">
    <style>
      .page-wrap { max-width: 1200px; margin: 0 auto; padding: 0 16px; }
      .page-title { font-size: 28px; font-weight: 800; color: #e0e0e0; padding: 32px 0 8px; }
      .page-desc { color: #888; font-size: 15px; margin-bottom: 24px; }
      .content-sidebar-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
        padding: 32px 0 0;
        min-width: 0;
      }
      .content-sidebar-layout > * { min-width: 0; }
      @media (min-width: 900px) {
        .content-sidebar-layout { grid-template-columns: 1fr 320px; }
      }
      .league-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
      }
      .league-card {
        display: block;
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 24px;
        text-decoration: none;
        transition: all 0.2s;
      }
      .league-card:hover {
        border-color: #ff0037;
        transform: translateY(-2px);
        box-shadow: 0 4px 20px rgba(255,0,55,0.15);
      }
      .league-card h3 {
        font-size: 18px;
        font-weight: 700;
        color: #e0e0e0;
        margin-bottom: 6px;
      }
      .league-card p {
        font-size: 13px;
        color: #888;
      }
      .league-card:hover h3 { color: #ff0037; }
    </style>
    <h1 class="page-title">Leagues</h1>
    <p class="page-desc">Browse football leagues and competitions.</p>
    <div class="content-sidebar-layout">
      <div>
        <div class="league-grid">
          <a href="/ucl" class="league-card">
            <h3>UCL</h3>
            <p>UEFA Champions League</p>
          </a>
          <a href="/premier-league" class="league-card">
            <h3>Premier League</h3>
            <p>English Premier League</p>
          </a>
          <a href="/laliga" class="league-card">
            <h3>LaLiga</h3>
            <p>Spanish La Liga</p>
          </a>
          <a href="/ligue-1" class="league-card">
            <h3>Ligue 1</h3>
            <p>French Ligue 1</p>
          </a>
          <a href="/serie-a" class="league-card">
            <h3>Serie A</h3>
            <p>Italian Serie A</p>
          </a>
          <a href="/bundesliga" class="league-card">
            <h3>Bundesliga</h3>
            <p>German Bundesliga</p>
          </a>
        </div>
      </div>
      <Sidebar client:only="react" />
    </div>
    <LatestNews client:only="react" />
  </div>
  <Player />
</Layout>
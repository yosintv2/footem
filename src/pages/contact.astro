---
import Layout from '../layouts/Layout.astro';
import { config } from '../config';
---

<Layout title={`${config.contact.pageTitle}${config.site.name} | ${config.site.tagline}`}>
  <div class="page-wrap">
    <style>
      .page-wrap { max-width: 800px; margin: 0 auto; padding: 40px 16px; }
      h1 { font-size: 32px; font-weight: 800; color: #e0e0e0; margin-bottom: 24px; }
      p { color: #aaa; line-height: 1.8; margin-bottom: 16px; font-size: 16px; }
      .contact-list { list-style: none; padding: 0; }
      .contact-list li { padding: 12px 0; border-bottom: 1px solid #2a2a2a; color: #aaa; font-size: 16px; }
      .contact-list li strong { color: #e0e0e0; display: inline-block; width: 120px; }
      .contact-list a { color: #ff0037; }
    </style>
    <h1>{config.contact.heading}</h1>
    <p>{config.contact.description}</p>
    <ul class="contact-list">
      <li><strong>{config.contact.labels.email}</strong> <a href={`mailto:${config.contact.email}`}>{config.contact.email}</a></li>
      <li><strong>{config.contact.labels.whatsapp}</strong> <a href={config.links.social.whatsapp}>{config.socialDisplay.whatsapp.handle}</a></li>
      <li><strong>{config.contact.labels.twitter}</strong> <a href={config.links.social.twitter}>{config.socialDisplay.twitter.handle}</a></li>
      <li><strong>{config.contact.labels.facebook}</strong> <a href={config.links.social.facebook}>{config.socialDisplay.facebook.handle}</a></li>
      <li><strong>{config.contact.labels.instagram}</strong> <a href={config.links.social.instagram}>{config.socialDisplay.instagram.handle}</a></li>
    </ul>
  </div>
</Layout>

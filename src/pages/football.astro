---
import Layout from '../layouts/Layout.astro';
import MatchList from '../components/MatchList';
import Sidebar from '../components/Sidebar';

import LatestNews from '../components/LatestNews';
import { config } from '../config';
---

<Layout   title={`Football Matches - ${config.site.name}`}>
  <div class="page-wrap">
    <style>
      .page-wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 16px;
        background: #fff;
      }
      .content-sidebar-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
        padding: 24px 0 0;
        min-width: 0;
      }
      .content-sidebar-layout > * {
        min-width: 0;
      }
      @media (min-width: 900px) {
        .content-sidebar-layout {
          grid-template-columns: 1fr 320px;
        }
      }
      .football-apk-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 14px 20px;
        margin: 16px 0;
        background: linear-gradient(135deg, #ff0037, #ff6b35);
        color: #fff;
        font-weight: 700;
        font-size: 15px;
        border: none;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        max-width: 1000px;
      }
      .football-apk-btn:hover {
        opacity: 0.92;
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(255, 0, 55, 0.3);
      }
    </style>

    <div class="content-sidebar-layout">
      <div>
        <MatchList
          apiUrl={config.api.football}
          title="Football Matches"
          client:only="react"
        />

        <a href={config.links.apk} class="football-apk-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download YoSinTV APK
        </a>
      </div>
      <Sidebar client:only="react" />
    </div>
    <div style="background:#fff;text-align:center;padding:0;min-height:0;display:flex;align-items:center;justify-content:center;max-width:1200px;margin:0 auto;">
      <ins class="adsbygoogle"
           style="display:block;background:transparent;"
           data-ad-client={config.ads.google.client}
           data-ad-slot={config.ads.google.slots.betweenMatch}
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
    </div>
    <LatestNews client:only="react" />
  </div>
</Layout>

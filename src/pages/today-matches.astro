---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar';
import LatestNews from '../components/LatestNews';
import TodayMatches from '../components/TodayMatches';
import { config } from '../config';

const pageTitle = `Today's Matches - ${config.site.name}`;
const pageDesc = `View all football matches happening today. Live scores, lineups, previews and streaming.`;
---

<Layout title={pageTitle} description={pageDesc}>
  <style>
    .tm-wrap { max-width: 1200px; margin: 0 auto; padding: 0 16px 60px; }
    .tm-layout { display: grid; grid-template-columns: 1fr; gap: 32px; padding-top: 12px; }
    @media (min-width: 900px) {
      .tm-layout { grid-template-columns: 1fr 320px; }
    }
  </style>

  <div class="tm-wrap">
    <div class="tm-layout">
      <div>
        <TodayMatches client:only="react" />
      </div>
      <div>
        <Sidebar client:only="react" />
      </div>
    </div>
  </div>
</Layout>

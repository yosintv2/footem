---
// Shared iframe player partial — used by homepage + all league pages
// Shows when ?src=<url> is present in the URL
import { config } from '../config';
const { brand = config.player.brand } = Astro.props;
---

<div id="footem-player" style="display:none">
  <style is:global>
    #footem-player { display: none; background: #ffffff; min-height: 100vh; flex-direction: column; font-family: 'Inter', -apple-system, sans-serif; }
    #footem-player.show { display: flex; }
    .fp-header { background: linear-gradient(135deg, #ff0037, #cc0029); color: #fff; text-align: center; padding: 12px; font-size: 20px; font-weight: 800; letter-spacing: 1px; }
    .fp-notice { background: #f5f5f5; color: #333; text-align: center; padding: 8px 14px; font-size: 13px; font-weight: 600; border-bottom: 1px solid #e0e0e0; }
    .fp-wrapper { flex: 1; background: #000; display: flex; align-items: center; justify-content: center; padding: 20px; min-height: 60vh; position: relative; }
    .fp-wrapper iframe { width: 100%; max-width: 900px; height: 100%; min-height: 50vh; border: none; border-radius: 8px; }
    .fp-loader { position: absolute; width: 50px; height: 50px; border: 5px solid #ddd; border-top: 5px solid #ff0037; border-radius: 50%; animation: fp-spin 1s linear infinite; }
    .fp-loader.hide { display: none; }
    @keyframes fp-spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    .fp-error { position: absolute; inset: 0; background: rgba(0,0,0,0.95); display: none; flex-direction: column; align-items: center; justify-content: center; color: #fff; z-index: 10; }
    .fp-error.show { display: flex; }
    .fp-error p { font-size: 18px; margin-bottom: 16px; }
    .fp-error button { padding: 10px 24px; border-radius: 8px; border: none; background: #ff0037; color: #fff; font-weight: 700; cursor: pointer; }
    .fp-actions { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; padding: 12px; background: #f5f5f5; border-top: 1px solid #e0e0e0; }
    .fp-btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: 8px; font-weight: 700; font-size: 14px; text-decoration: none; color: #333; background: rgba(0,0,0,0.06); border: 1px solid rgba(0,0,0,0.1); cursor: pointer; transition: all 0.2s; }
    .fp-btn:hover { background: rgba(0,0,0,0.1); color: #222; }
    .fp-btn.primary { background: #25D366; border-color: #25D366; color: #fff; }
    .fp-btn.primary:hover { opacity: 0.9; }
    .fp-dmca { padding: 16px; background: #ffffff; border-top: 1px solid #e0e0e0; text-align: center; }
    .fp-dmca h4 { color: #ff0037; font-size: 14px; font-weight: 800; text-transform: uppercase; margin-bottom: 6px; }
    .fp-dmca p { color: #666; font-size: 12px; line-height: 1.6; max-width: 700px; margin: 0 auto; }
  </style>
  <div class="fp-header">{brand}</div>
  <div class="fp-notice">{config.player.notice}</div>
  <div class="fp-wrapper">
    <div class="fp-loader" id="fp-loader"></div>
    <iframe id="fp-iframe" allow="autoplay; encrypted-media" allowfullscreen></iframe>
    <div class="fp-error" id="fp-error">
      <p id="fp-err-msg">{config.player.noStreamMessage}</p>
      <button onclick="location.reload()">{config.player.retryText}</button>
    </div>
  </div>
  <div class="fp-actions">
    <a class="fp-btn primary" href={config.links.social.whatsapp} target="_blank">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      {config.player.whatsappText}
    </a>
    <button class="fp-btn" onclick="fpShare()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
      {config.player.shareText}
    </button>
  </div>
  <div class="fp-dmca">
    <h4>{config.player.dmcaHeading}</h4>
    <p>{config.player.dmcaText}</p>
  </div>
  </div>
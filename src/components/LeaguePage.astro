---
// Shared league page template — renders matches + sidebar + news + player
import Layout from '../layouts/Layout.astro';
import MatchList from '../components/MatchList';
import Sidebar from '../components/Sidebar';
import LatestNews from '../components/LatestNews';
import Player from './Player.astro';
import { config } from '../config';

export interface Props {
  title: string;
  leagueKey: string;
  apiKey?: string;
  pageTitle?: string;
}

const { title, apiKey = 'football', pageTitle } = Astro.props;
const apiUrl = config.api[apiKey as keyof typeof config.api] as string || config.api.football;
const seoTitle = pageTitle || `${title} - ${config.site.name} | ${config.site.tagline}`;
---

<Layout title={seoTitle}>
  <div class="site-content">
    <style>
      .page-layout { max-width: 1200px; margin: 0 auto; padding: 0 16px; }
      .content-sidebar-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
        padding: 32px 0 0;
        min-width: 0;
      }
      .content-sidebar-layout > * { min-width: 0; }
      @media (min-width: 900px) {
        .content-sidebar-layout { grid-template-columns: 1fr 320px; }
      }
    </style>
    <div class="page-layout">
      <div class="content-sidebar-layout">
        <div>
          <MatchList apiUrl={apiUrl} title={title} client:only="react" />
        </div>
        <Sidebar client:only="react" />
      </div>
      <LatestNews client:only="react" />
    </div>
  </div>
  <Player brand={config.player.brand} />
</Layout>